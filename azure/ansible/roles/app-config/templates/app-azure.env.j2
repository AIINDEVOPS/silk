# Azure application environment config - managed by Ansible
APP_NAME={{ app_name }}
APP_ENV={{ app_env }}
SECRET_KEY={{ vault_secret_key | default('change-me') }}
PLATFORM=azure

# Azure Blob Storage (replaces AWS S3)
AZURE_STORAGE_ACCOUNT={{ azure_storage_account }}
AZURE_CONTAINER_NAME={{ azure_container_name }}

# Logging
LOG_LEVEL={{ log_level }}
FLASK_ENV={{ 'development' if app_env == 'dev' else 'production' }}
