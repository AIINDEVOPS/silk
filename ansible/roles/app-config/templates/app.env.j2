# Application environment config - managed by Ansible
# Do NOT edit manually

APP_NAME={{ app_name }}
APP_ENV={{ app_env }}
SECRET_KEY={{ vault_secret_key | default('change-me') }}

# AWS Configuration
AWS_REGION={{ aws_region }}
S3_BUCKET={{ s3_bucket }}

# Logging
LOG_LEVEL={{ log_level }}

# Flask
FLASK_ENV={{ 'development' if app_env == 'dev' else 'production' }}
